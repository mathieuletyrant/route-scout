{
  "name": "route-scout-cli",
  "version": "0.2.1",
  "description": "Find where each OpenAPI endpoint is used across your codebase.",
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/mathieuletyrant/route-scout.git",
    "directory": "packages/cli"
  },
  "keywords": [
    "openapi",
    "swagger",
    "cli",
    "usage",
    "dead-code",
    "endpoints"
  ],
  "bin": {
    "route-scout": "./dist/cli.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "compile": "node esbuild.mjs",
    "watch": "node esbuild.mjs --watch",
    "build": "node esbuild.mjs --minify",
    "typecheck": "tsc -p tsconfig.typecheck.json",
    "test": "vitest run --passWithNoTests",
    "prepublishOnly": "node esbuild.mjs --minify"
  },
  "devDependencies": {
    "@route-scout/core": "workspace:*",
    "@types/node": "^22.10.7",
    "esbuild": "^0.24.2",
    "typescript": "^7.0.2",
    "vitest": "^4.1.0"
  },
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  }
}
